<Window x:Class="MAMDesk.Operator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAMDesk Operator"
        Height="640" Width="980"
        MinHeight="520" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ContentBgGradient}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarGradient}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="22,28,22,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="10" Background="#3B82F633" Margin="0,0,12,0">
                            <TextBlock Text="MD" FontWeight="Bold" Foreground="#93C5FD"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="MAMDesk" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Operador" FontSize="11" Foreground="#94A3B8"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Background="#1E293B88" CornerRadius="10" Padding="12,10" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Logado como" FontSize="10" Foreground="#64748B"/>
                            <TextBlock x:Name="UserNameText" Text="Operador" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#E2E8F0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="14,0">
                    <Button x:Name="NavConnectBtn" Content="  Conectar" Style="{StaticResource NavButton}"
                            Tag="active" Click="NavConnectBtn_Click"/>
                    <Button x:Name="NavDevicesBtn" Content="  Dispositivos" Style="{StaticResource NavButton}"
                            Click="NavDevicesBtn_Click"/>
                    <Button x:Name="NavSettingsBtn" Content="  Configurações" Style="{StaticResource NavButton}"
                            Click="NavSettingsBtn_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="22,0,22,20">
                    <TextBlock Text="v0.2" FontSize="11" Foreground="#475569"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Conteúdo -->
        <Grid Grid.Column="1" Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Conectar -->
            <Border x:Name="ConnectPanel" Grid.Row="0" Style="{StaticResource PanelCard}" Padding="36" VerticalAlignment="Top">
                <StackPanel MaxWidth="440">
                    <TextBlock Text="Nova conexão" FontSize="24" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Informe o ID e a senha exibidos no Quick Support do cliente."
                               FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,28" LineHeight="20"/>

                    <TextBlock Text="ID do dispositivo" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="DeviceIdBox" Style="{StaticResource ModernTextBox}"
                             FontSize="20" FontFamily="Consolas" Margin="0,0,0,18" MaxLength="11"/>

                    <TextBlock Text="Senha de sessão" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="PasswordBox" Style="{StaticResource ModernTextBox}"
                             FontSize="20" FontFamily="Consolas" Margin="0,0,0,24" MaxLength="8"/>

                    <TextBlock x:Name="ConnectErrorText" Foreground="{StaticResource DangerBrush}"
                               FontSize="12" Margin="0,0,0,14" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <Button x:Name="ConnectBtn" Content="Iniciar conexão remota" Style="{StaticResource PrimaryButton}"
                            Click="ConnectBtn_Click"/>
                </StackPanel>
            </Border>

            <!-- Dispositivos -->
            <Border x:Name="DevicesPanel" Grid.Row="0" Style="{StaticResource PanelCard}" Padding="28"
                    Visibility="Collapsed" VerticalAlignment="Stretch" Effect="{StaticResource SoftShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Meus dispositivos" FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Histórico pessoal — PCs que você já acessou."
                                       FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="RefreshDevicesBtn" Content="↻ Atualizar"
                                Style="{StaticResource SecondaryButton}" Padding="14,10"
                                Click="RefreshDevicesBtn_Click" IsEnabled="True"/>
                    </Grid>

                    <TextBlock x:Name="DevicesLoadingText" Grid.Row="1" Text="Carregando dispositivos..."
                               Foreground="{StaticResource MutedBrush}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,24" Visibility="Collapsed"/>

                    <StackPanel x:Name="DevicesEmptyText" Grid.Row="1" VerticalAlignment="Top"
                                HorizontalAlignment="Center" Visibility="Collapsed" Margin="0,24">
                        <TextBlock Text="Nenhum dispositivo ainda"
                                   FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Conecte pela primeira vez na aba Conectar."
                                   FontSize="13" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0" TextAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer x:Name="DevicesScrollViewer" Grid.Row="1" MaxHeight="460"
                                  VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <ItemsControl x:Name="DevicesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="12" Padding="16,14" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                                             Fill="{Binding OnlineIndicatorBrush}"/>
                                                    <TextBlock Text="{Binding NomePc}" FontSize="15" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}"/>
                                                </StackPanel>
                                                <TextBlock Margin="16,4,0,0" FontFamily="Consolas" FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Text="{Binding DeviceUid}"/>
                                                <TextBlock Margin="16,2,0,0" FontSize="11" Foreground="#94A3B8"
                                                           Text="{Binding DetailLine}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Acessar" Style="{StaticResource PrimaryButton}"
                                                    Padding="18,10" VerticalAlignment="Center"
                                                    Click="AccessDeviceBtn_Click" Tag="{Binding}"
                                                    IsEnabled="{Binding Online}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Configurações -->
            <Border x:Name="SettingsPanel" Grid.Row="0" Style="{StaticResource PanelCard}" Padding="36"
                    Visibility="Collapsed" VerticalAlignment="Top">
                <StackPanel MaxWidth="480">
                    <TextBlock Text="Configurações" FontSize="24" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Preferências salvas em %AppData%\MAMDesk\operator.json"
                               FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,28"/>

                    <TextBlock Text="Nome exibido no PC remoto" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="DisplayNameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Qualidade de vídeo" FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="QualityValueText" Grid.Column="1" Text="92%" FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="QualitySlider" Minimum="60" Maximum="95" Value="92"
                            Margin="0,0,0,20" ValueChanged="QualitySlider_ValueChanged"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Escala da tela" FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ScaleValueText" Grid.Column="1" Text="95%" FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="ScaleSlider" Minimum="70" Maximum="100" Value="95"
                            Margin="0,0,0,20" ValueChanged="ScaleSlider_ValueChanged"/>

                    <TextBlock Text="Servidor" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="ServerUrlBox" Style="{StaticResource ModernTextBox}"
                             IsReadOnly="True" Margin="0,0,0,8" Opacity="0.85"/>
                    <TextBlock x:Name="ProfilePathText" FontSize="10" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,24"/>

                    <Button x:Name="SaveSettingsBtn" Content="Salvar alterações" Style="{StaticResource PrimaryButton}"
                            Click="SaveSettingsBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
