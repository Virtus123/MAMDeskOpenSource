<Window x:Class="MAMDesk.Operator.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAMDesk Operator"
        Height="520" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Hero lateral -->
        <Border Grid.Column="0" Background="{StaticResource LoginHeroGradient}">
            <Grid Margin="36,40">
                <StackPanel VerticalAlignment="Center">
                    <Border Width="56" Height="56" CornerRadius="14" Background="#FFFFFF22" Margin="0,0,0,20">
                        <TextBlock Text="MD" FontSize="22" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="MAMDesk" FontSize="32" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Acesso remoto profissional" FontSize="14" Foreground="#E0E7FF"
                               Margin="0,8,0,0" Opacity="0.9"/>
                    <TextBlock Text="Conecte, gerencie e dê suporte com segurança."
                               FontSize="13" Foreground="#C7D2FE" Margin="0,24,0,0"
                               TextWrapping="Wrap" LineHeight="22" Opacity="0.85"/>
                </StackPanel>
                <TextBlock VerticalAlignment="Bottom" Text="© MAM Acesso" FontSize="11" Foreground="#FFFFFF66"/>
            </Grid>
        </Border>

        <!-- Formulário -->
        <Grid Grid.Column="1" Margin="48,40">
            <StackPanel VerticalAlignment="Center" MaxWidth="360">
                <TextBlock Text="Bem-vindo de volta" FontSize="26" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Entre com sua conta de operador" FontSize="14"
                           Foreground="{StaticResource MutedBrush}" Margin="0,6,0,28"/>

                <Border Style="{StaticResource PanelCard}" Padding="28" Effect="{StaticResource SoftShadow}">
                    <StackPanel>
                        <TextBlock Text="E-mail" FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                        <TextBox x:Name="EmailBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                        <TextBlock Text="Senha" FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,20"/>

                        <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>

                        <Button x:Name="LoginBtn" Content="Entrar" Style="{StaticResource PrimaryButton}"
                                Click="LoginBtn_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
