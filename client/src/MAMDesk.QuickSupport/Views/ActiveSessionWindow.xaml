<Window x:Class="MAMDesk.QuickSupport.Views.ActiveSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAMDesk - Sessão ativa"
        Width="300" Height="130"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Border Background="#F0FFFFFF" CornerRadius="10" BorderBrush="#CBD5E1" BorderThickness="1"
            Padding="14,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                <Ellipse Width="10" Height="10" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Acesso remoto ativo" FontWeight="SemiBold" FontSize="13" Foreground="#0F172A"/>
            </StackPanel>
            <TextBlock x:Name="OperatorNameText" Grid.Row="1" Text="Operador conectado"
                       FontSize="12" Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,10"/>
            <Button Grid.Row="2" Content="Encerrar conexão" Padding="10,6" Cursor="Hand"
                    Click="EndSessionBtn_Click"
                    Background="#DC2626" Foreground="White" BorderThickness="0" FontSize="12"/>
        </Grid>
    </Border>
</Window>
