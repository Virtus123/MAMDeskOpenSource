<Application x:Class="MAMDesk.QuickSupport.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="BgBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#64748B"/>
    </Application.Resources>
</Application>
