# Copie para deploy/.env e preencha (NUNCA commite deploy/.env)
MAMDESK_VPS_HOST=seu-servidor.exemplo.com
MAMDESK_VPS_USER=root
MAMDESK_VPS_PASSWORD=
# Ou use chave SSH em vez de senha:
# MAMDESK_VPS_SSH_KEY=C:\Users\voce\.ssh\id_ed25519

# Caminho remoto da instalação
MAMDESK_INSTALL_DIR=/opt/mamdesk
MAMDESK_WWW_DIR=/opt/mamdesk/www
MAMDESK_API_PORT=8100

# Domínio do site (deploy_site.py, nginx)
MAMDESK_SITE_DOMAIN=mamdesk.exemplo.com
MAMDESK_CERTBOT_EMAIL=admin@exemplo.com

# Seed admin na primeira instalação (remote_deploy.py — opcional)
# MAMDESK_ADMIN_EMAIL=admin@exemplo.com
# MAMDESK_ADMIN_PASSWORD=troque-esta-senha
# MAMDESK_DB_PASSWORD=gerar-senha-forte-para-postgres
